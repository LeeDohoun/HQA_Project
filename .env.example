# ==========================================
# HQA Project - 환경 변수 설정
# ==========================================
# 이 파일을 복사하여 .env 파일로 저장하세요:
#   cp .env.example .env
# ==========================================

# ------------------------------------------
# 1. LLM 설정 (Provider 패턴)
# ------------------------------------------
# LLM_PROVIDER로 Ollama / Gemini 전환 가능
# 기본값: ollama (로컬 GPU 필요)
LLM_PROVIDER=ollama

# --- 옵션 A: Ollama (로컬 LLM) ---
# 설치: https://ollama.com/download
# 모델 다운로드 후 서버 실행: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_INSTRUCT_MODEL=llama3.1:8b
OLLAMA_THINKING_MODEL=deepseek-r1:14b
OLLAMA_VISION_MODEL=llava:13b

# --- 옵션 B: Gemini (Google Cloud API) ---
# LLM_PROVIDER=gemini 으로 변경 후 아래 설정 사용
# 발급: https://aistudio.google.com/
# 필수: pip install langchain-google-genai
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GEMINI_INSTRUCT_MODEL=gemini-2.5-flash-lite
# GEMINI_THINKING_MODEL=gemini-2.5-flash-preview-04-17
# GEMINI_VISION_MODEL=gemini-2.5-flash-preview-04-17

# ------------------------------------------
# 2. 한국투자증권 API (선택 - 실시간 시세)
# ------------------------------------------
# 용도: 실시간 주가, 호가, 체결 조회
# 발급: https://apiportal.koreainvestment.com/
# 참고: 모의투자/실전투자 선택 가능
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here
KIS_ACCOUNT_NO=your_account_number_here
# 실전투자: KIS_IS_REAL=true (기본값: 모의투자)
# KIS_IS_REAL=false

# ------------------------------------------
# 3. DART 공시 API (선택 - 공시 검색)
# ------------------------------------------
# 용도: 기업 공시, 재무제표, 사업보고서
# 발급: https://opendart.fss.or.kr/
DART_API_KEY=your_dart_api_key_here

# ------------------------------------------
# 4. Tavily API (선택 - 웹 검색)
# ------------------------------------------
# 용도: 실시간 뉴스, 웹 검색
# 발급: https://tavily.com/
# 참고: 무료 월 1,000건, 미설정 시 DuckDuckGo 사용
TAVILY_API_KEY=your_tavily_api_key_here

# ==========================================
# 5. 프로덕션 설정 (웹 서비스 배포 시)
# ==========================================

# ── 환경 ──
# ENV=local                      # local | dev | staging | production
# DEBUG=false
# PORT=8000

# ── OCR 프로바이더 ──
# local = PaddleOCR (GPU 필요), upstage = Upstage API (GPU 불필요)
# OCR_PROVIDER=local
# UPSTAGE_API_KEY=               # https://developers.upstage.ai/

# ── Reranker 프로바이더 ──
# local = Qwen3 (GPU 필요), cohere = Cohere API (GPU 불필요)
# RERANKER_PROVIDER=local
# COHERE_API_KEY=                # https://cohere.com/

# ── 데이터베이스 (PostgreSQL) ──
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/hqa

# ── Redis (Task Queue) ──
# REDIS_URL=redis://localhost:6379/0

# ── AI 서버 (분리 배포 시) ──
# 로컬 개발: http://localhost:8001
# Docker: http://ai:8001 (docker-compose.yml에서 자동 설정)
# AI_SERVER_URL=http://localhost:8001

# ── 벡터 DB ──
# VECTOR_DB_PROVIDER=chroma
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=hqa-stocks

# ── LangSmith 모니터링 ──
# LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=hqa-production

# ── 보안 ──
# SECRET_KEY=change-me-in-production
# RATE_LIMIT_PER_MINUTE=30
# CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# ==========================================
# 설정 완료 후:
#   python main.py                          # CLI 모드
#   uvicorn backend.app:app --reload        # API 서버
#   docker-compose up                       # 프로덕션
