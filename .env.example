# ==========================================
# HQA Data Pipeline - 환경 변수 설정
# cp .env.example .env-data
# ==========================================

# ── DART 공시 API (기업 공시, 재무제표 수집) ──
# 발급: https://opendart.fss.or.kr/
DART_API_KEY=your_dart_api_key_here

# ── 한국투자증권 API (주가 데이터 수집) ──
# 발급: https://apiportal.koreainvestment.com/
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here
KIS_ACCOUNT_NO=your_account_number_here

# ==========================================
# 실행:
#   python pipeline_runner.py ingest --code 005930 --name 삼성전자
#   python pipeline_runner.py ingest-batch --codes 005930,000660
#   python pipeline_runner.py search --query "삼성전자 실적"
# ==========================================
