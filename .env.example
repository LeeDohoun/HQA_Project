# ==========================================
# HQA Project - 환경 변수 설정
# ==========================================
# 이 파일을 복사하여 .env 파일로 저장하세요:
#   cp .env.example .env
# ==========================================

# ------------------------------------------
# 1. Ollama 설정 (필수)
# ------------------------------------------
# 용도: 로컬 LLM (에이전트 추론, 분석, 임베딩)
# 설치: https://ollama.com/download
# 모델 다운로드 후 서버 실행: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_INSTRUCT_MODEL=llama3.1:8b
OLLAMA_THINKING_MODEL=deepseek-r1:14b
OLLAMA_VISION_MODEL=llava:13b
OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_RERANKER_MODEL=llama3.1:8b  # 리랭킹용 (미지정 시 기본값 사용)

# (레거시 - Ollama 사용 시 불필요)
# GOOGLE_API_KEY=your_gemini_api_key_here

# ------------------------------------------
# 2. 한국투자증권 API (선택 - 실시간 시세)
# ------------------------------------------
# 용도: 실시간 주가, 호가, 체결 조회
# 발급: https://apiportal.koreainvestment.com/
# 참고: 모의투자/실전투자 선택 가능
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here
KIS_ACCOUNT_NO=your_account_number_here
# 실전투자: KIS_IS_REAL=true (기본값: 모의투자)
# KIS_IS_REAL=false

# ------------------------------------------
# 3. DART 공시 API (선택 - 공시 검색)
# ------------------------------------------
# 용도: 기업 공시, 재무제표, 사업보고서
# 발급: https://opendart.fss.or.kr/
DART_API_KEY=your_dart_api_key_here

# ------------------------------------------
# 4. Tavily API (선택 - 웹 검색)
# ------------------------------------------
# 용도: 실시간 뉴스, 웹 검색
# 발급: https://tavily.com/
# 참고: 무료 월 1,000건, 미설정 시 DuckDuckGo 사용
TAVILY_API_KEY=your_tavily_api_key_here

# ==========================================
# 설정 완료 후:
#   python main.py
# ==========================================
