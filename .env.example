# ==========================================
# HQA 통합 런타임 설정 예시
# cp .env.example .env
# ==========================================

# ── 필수 또는 강력 권장 ──
# 기본 런타임: Ollama
LLM_PROVIDER=ollama

# ai-data-main / rag-data-pipeline 산출물이 함께 저장될 기본 데이터 루트입니다.
# 상대 경로는 프로젝트 루트를 기준으로 해석됩니다.
HQA_DATA_DIR=./data

# --- Ollama 기본값 ---
# 설치: https://ollama.com/download
# 실행: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_INSTRUCT_MODEL=qwen3.5:9b
OLLAMA_THINKING_MODEL=gemma4:e4b

# 선택: 최종 의사결정 교차검증 모델
OLLAMA_THINKING_VALIDATOR_MODEL=

# 선택: 이미지/차트 비전 분석을 사용할 때만 필요
OLLAMA_VISION_MODEL=llava:13b

# 선택: retrieval 연결만 확인하는 스모크 테스트 모드
# 운영 환경에서는 사용하지 않습니다.
# LLM_PROVIDER=mock

# ── 선택: LLM 제공자 변경 ──
# Ollama 대신 Gemini를 사용할 때만 주석을 해제하세요.
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_API_KEY=your_google_api_key_here  # GOOGLE_API_KEY 대신 사용 가능
# GEMINI_INSTRUCT_MODEL=gemini-2.5-flash-lite
# GEMINI_THINKING_MODEL=gemini-2.5-pro
# GEMINI_THINKING_VALIDATOR_MODEL=gemini-2.5-flash
# GEMINI_VISION_MODEL=gemini-2.5-flash

# ── 선택: 데이터/출력 경로 재정의 ──
# HQA_TRACES_DIR=./data/traces
# HQA_ORDERS_DIR=./data/orders

# ── 선택: 검색 / retrieval API ──
# 비워두면 웹 검색은 가능한 경우 DuckDuckGo 폴백을 사용합니다.
TAVILY_API_KEY=

# ── 선택: 파이프라인 API ──
# DART 공시 수집을 실제로 돌릴 때만 필요합니다.
DART_API_KEY=

# ── 선택: OCR / reranker 제공자 ──
# 별도 설정이 없으면 기본적으로 비활성화되거나 로컬 전용으로 동작합니다.
OCR_PROVIDER=local
ENABLE_OCR=false
# UPSTAGE_API_KEY=

RERANKER_PROVIDER=local
# COHERE_API_KEY=

# ── 선택: 실시간 시세 / 거래 연동 ──
# 실시간 시세 조회나 한국투자증권 Open API 주문 경로를 사용할 때 필요합니다.
# 모의투자 자동매매에는 아래 KIS_PAPER_* 값을 우선 사용합니다.
# 계좌번호는 12345678, 12345678-01, 1234567801 형식을 지원합니다.
# 8자리만 입력하면 계좌상품코드는 01로 보완합니다.
# KIS_PAPER_APP_KEY=
# KIS_PAPER_APP_SECRET=
# KIS_PAPER_ACCOUNT_NO=

# 실전투자 키는 명시적으로 필요한 경우에만 설정하세요.
# TradeExecutor는 allow_real_trading=true 설정 없이는 실전 주문을 차단합니다.
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_ACCOUNT_NO=

# ── 선택: 서버 / 관측성 설정 ──
REDIS_URL=redis://localhost:6379/0
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=hqa-ai

# ==========================================
# 실행 시 참고사항
# 1. .env 파일이 없어도 HQA는 기본값으로 부팅되지만,
#    시작 시 HQA_DATA_DIR 과 LLM 런타임 사용 가능 여부를 확인합니다.
# 2. Playwright 기반 종목토론방 크롤링을 쓰려면:
#    playwright install chromium
# 3. Ollama 기반 실행 시에는 에이전트 데모를 돌리기 전에
#    설정한 모델을 미리 pull 해두는 것을 권장합니다.
# ==========================================
