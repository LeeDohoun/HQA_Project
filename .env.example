# ==========================================
# HQA unified runtime configuration
# cp .env.example .env
# ==========================================

# ── Required / strongly recommended ──
# Default runtime: Ollama
LLM_PROVIDER=ollama

# Default data root for both ai-data-main and rag-data-pipeline artifacts.
# Relative paths are resolved from the project root.
HQA_DATA_DIR=./data

# --- Ollama defaults ---
# Install: https://ollama.com/download
# Start:   ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_INSTRUCT_MODEL=qwen3.5:9b
OLLAMA_THINKING_MODEL=gemma4:e4b

# Optional: enable final decision cross-check model
OLLAMA_THINKING_VALIDATOR_MODEL=

# Optional: only needed when image/chart vision analysis is enabled
OLLAMA_VISION_MODEL=llava:13b

# Optional smoke-test mode for retrieval wiring only.
# Not for production usage.
# LLM_PROVIDER=mock

# ── Optional LLM provider override ──
# Uncomment only when using Gemini instead of Ollama.
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_API_KEY=your_google_api_key_here  # GOOGLE_API_KEY 대신 사용 가능
# GEMINI_INSTRUCT_MODEL=gemini-2.5-flash-lite
# GEMINI_THINKING_MODEL=gemini-2.5-pro
# GEMINI_THINKING_VALIDATOR_MODEL=gemini-2.5-flash
# GEMINI_VISION_MODEL=gemini-2.5-flash

# ── Optional data/output path overrides ──
# HQA_TRACES_DIR=./data/traces
# HQA_ORDERS_DIR=./data/orders

# ── Optional retrieval / search APIs ──
# If omitted, web search falls back to DuckDuckGo where available.
TAVILY_API_KEY=

# ── Optional pipeline APIs ──
# Required only when you actually run DART collection.
DART_API_KEY=

# ── Optional OCR / reranker providers ──
# Default behavior keeps these features off or local-only unless configured.
OCR_PROVIDER=local
ENABLE_OCR=false
# UPSTAGE_API_KEY=

RERANKER_PROVIDER=local
# COHERE_API_KEY=

# ── Optional realtime / trading integration ──
# Required only for realtime quotes or live trading paths.
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_ACCOUNT_NO=

# ── Optional server / observability settings ──
REDIS_URL=redis://localhost:6379/0
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=hqa-ai

# ==========================================
# Runtime notes
# 1. If .env is missing, HQA will still boot with defaults, but
#    HQA_DATA_DIR and LLM runtime availability will be checked at startup.
# 2. For Playwright-based forum crawling:
#    playwright install chromium
# 3. For Ollama-based execution, make sure the configured models
#    are already pulled before running the agent demo.
# ==========================================
