# ==========================================
# HQA AI Server - 환경 변수 설정
# cp .env.example .env-ai
# ==========================================

# ── LLM Provider ──
# "ollama" = 로컬 GPU, "gemini" = Google API
LLM_PROVIDER=ollama

# --- 옵션 A: Ollama (로컬 LLM) ---
# 설치: https://ollama.com/download
# 실행: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_INSTRUCT_MODEL=llama3.1:8b
OLLAMA_THINKING_MODEL=deepseek-r1:14b
OLLAMA_VISION_MODEL=llava:13b

# --- 옵션 B: Gemini ---
# LLM_PROVIDER=gemini
# 발급: https://aistudio.google.com/
# GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_INSTRUCT_MODEL=gemini-2.5-flash-lite
# GEMINI_THINKING_MODEL=gemini-2.5-flash-preview-04-17
# GEMINI_VISION_MODEL=gemini-2.5-flash-preview-04-17

# ── DART 공시 API (기업 공시, 재무제표) ──
# 발급: https://opendart.fss.or.kr/
DART_API_KEY=your_dart_api_key_here

# ── Tavily API (웹 검색) ──
# 발급: https://tavily.com/
# 미설정 시 DuckDuckGo 사용 (무료, 제한 있음)
TAVILY_API_KEY=your_tavily_api_key_here

# ── OCR Provider ──
# "local" = PaddleOCR (GPU 필요), "upstage" = Upstage API
OCR_PROVIDER=local
# UPSTAGE_API_KEY=your_upstage_api_key_here   # https://developers.upstage.ai/
# IMAGE, PDF 기반 문서를 직접 수집하지 않는다면 GPU 절약을 위해 OCR을 임시 비활성화 할 수 있습니다. (기본값: false)
ENABLE_OCR=false

# ── Reranker Provider ──
# "local" = Qwen3 (GPU 필요), "cohere" = Cohere API
RERANKER_PROVIDER=local
# COHERE_API_KEY=your_cohere_api_key_here     # https://cohere.com/

# ── Vector DB ──
# "chroma" = 로컬 ChromaDB, "pinecone" = Pinecone
VECTOR_DB_PROVIDER=chroma
CHROMA_PERSIST_DIR=./database/chroma_db
# PINECONE_API_KEY=your_pinecone_api_key_here
# PINECONE_INDEX_NAME=hqa-stocks

# ── Redis (SSE 진행 상황 스트리밍) ──
REDIS_URL=redis://localhost:6379/0

# ── LangSmith 모니터링 (선택) ──
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=hqa-ai

# ==========================================
# 실행:
#   uvicorn ai_server.app:app --reload --host 0.0.0.0 --port 8001
# ==========================================
