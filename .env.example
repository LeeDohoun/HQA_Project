# ==========================================
# HQA 통합 런타임 설정
# 파일명: .env
# ==========================================

# ──────────────────────────────────────────
# 1. 기본 런타임 설정
# ──────────────────────────────────────────

LLM_PROVIDER=ollama

HQA_DATA_DIR=./data

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_INSTRUCT_MODEL=qwen3.5:9b
OLLAMA_THINKING_MODEL=gemma4:e4b
OLLAMA_THINKING_VALIDATOR_MODEL=
OLLAMA_VISION_MODEL=llava:13b


# ──────────────────────────────────────────
# 2. 선택: Gemini 사용 시
# Ollama 대신 Gemini를 쓸 때만 주석 해제
# ──────────────────────────────────────────

# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# GEMINI_INSTRUCT_MODEL=gemini-2.5-flash-lite
# GEMINI_THINKING_MODEL=gemini-2.5-pro
# GEMINI_THINKING_VALIDATOR_MODEL=gemini-2.5-flash
# GEMINI_VISION_MODEL=gemini-2.5-flash


# ──────────────────────────────────────────
# 3. 데이터 / 출력 경로
# ──────────────────────────────────────────

# HQA_TRACES_DIR=./data/traces
# HQA_ORDERS_DIR=./data/orders


# ──────────────────────────────────────────
# 4. 검색 / 공시 / 외부 API
# ──────────────────────────────────────────

TAVILY_API_KEY=

# DART 공시 수집을 실제로 사용할 때만 입력
DART_API_KEY=


# ──────────────────────────────────────────
# 5. OCR / Reranker
# ──────────────────────────────────────────

OCR_PROVIDER=local
ENABLE_OCR=false
# UPSTAGE_API_KEY=

RERANKER_PROVIDER=local
# COHERE_API_KEY=


# ──────────────────────────────────────────
# 6. KIS Open API - 모의투자
# 한국투자증권 모의투자 앱키 사용
# ──────────────────────────────────────────

KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=

# 계좌번호 형식 예시:
# 12345678
# 12345678-01
# 1234567801
#
# 8자리만 입력하면 기본 상품코드 01로 처리하도록 설계
KIS_PAPER_ACCOUNT_NO=

# 웹소켓, 체결통보, 조건검색 등에 필요한 HTS ID
# 현재 코드에서 읽지 않는다면 settings loader 또는 kis_auth.py에 연결 필요
KIS_PAPER_HTS_ID=


# ──────────────────────────────────────────
# 7. KIS Open API - 실전투자
# 실제 주문 가능성이 있으므로 반드시 주의
# ──────────────────────────────────────────

KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=

# 실전투자용 HTS ID
KIS_HTS_ID=


# ──────────────────────────────────────────
# 8. KIS 계좌 상품코드
# 일반 국내주식 위탁계좌는 보통 01
# ──────────────────────────────────────────

KIS_ACCOUNT_PRODUCT_CODE=01

# 참고:
# 01 = 종합계좌 / 위탁계좌
# 03 = 국내선물옵션
# 08 = 해외선물옵션
# 22 = 개인연금
# 29 = 퇴직연금


# ──────────────────────────────────────────
# 9. KIS 실행 환경 기본값
# ──────────────────────────────────────────

# prod = 실전투자
# vps  = 모의투자
KIS_DEFAULT_SERVER=vps

# 국내주식 기준
KIS_DEFAULT_PRODUCT=01

# 실전 주문 보호용
# 실제 주문 실행 코드에서 별도로 true 검사를 하도록 권장
ALLOW_REAL_TRADING=false


# ──────────────────────────────────────────
# 10. 서버 / 관측성
# ──────────────────────────────────────────

REDIS_URL=redis://localhost:6379/0

# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=hqa-ai