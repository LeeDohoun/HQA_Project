# ==========================================
# HQA Frontend - 환경 변수 설정
# cp .env.example .env-fe
# .env.example 파일을 .env-fe로 복사하여 사용하세요
# ==========================================

# ── Backend API URL ──
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Backend WebSocket URL ──
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ==========================================
# 실행:
#   npm install
#   npm run dev
# ==========================================
